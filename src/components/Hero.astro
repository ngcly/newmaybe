---
import { SITE } from '../config';
---

<section class="hero">
  <div class="wrap">
    <div class="hero-eyebrow">Sparse. Still.</div>
    <h1>
      <span class="word" style="animation-delay:.22s">以</span><span class="word accent" style="animation-delay:.32s">留白，</span><br />
      <span class="word" style="animation-delay:.42s">给念头</span><span class="word" style="animation-delay:.52s">余地。</span>
    </h1>
    <p class="lede">我在这里写字、记事、安放那些还没成形的念头。一切都还有余地，而这正是它温柔的地方。慢慢来。</p>
    <div class="hero-meta">
      <a href="/writing">阅读近作 →</a>
      <span class="scroll-hint">往下读 <span class="arr">↓</span></span>
    </div>
  </div>
  <div class="hero-stamp">Est. {SITE.startYear} · {SITE.url.replace('https://', '')}</div>
</section>

<style>
  .hero {
    min-height: calc(100vh - 72px);
    display: flex; flex-direction: column; justify-content: center;
    position: relative;
  }
  .hero-eyebrow {
    font-family: var(--serif-en);
    font-style: italic; font-size: 1.15rem;
    color: var(--ochre); letter-spacing: .04em;
    margin-bottom: 1.5rem;
    opacity: 0; transform: translateY(20px);
    animation: rise .6s ease forwards .12s;
  }
  .hero h1 {
    font-weight: 500;
    font-size: clamp(2.8rem, 7vw, 5.6rem);
    line-height: 1.25; letter-spacing: 0.05em;
    margin-bottom: 2rem; max-width: 14ch;
  }
  .hero h1 .word {
    display: inline-block;
    opacity: 0; transform: translateY(28px);
    animation: rise .65s cubic-bezier(.2,.7,.3,1) forwards;
  }
  .hero h1 .accent {
    color: var(--ochre);
    font-weight: 500;
  }
  .hero p.lede {
    font-size: 1.18rem; color: var(--ink-soft);
    max-width: 48ch; line-height: 1.9; font-weight: 300;
    opacity: 0; transform: translateY(20px);
    animation: rise .65s ease forwards .58s;
  }
  .hero-meta {
    margin-top: 3.5rem; display: flex; align-items: center; gap: 1.5rem;
    opacity: 0; animation: fade .8s ease forwards .72s;
  }
  .hero-meta a {
    font-family: var(--serif-en); font-size: 1.05rem;
    color: var(--ink); text-decoration: none;
    border: 1px solid var(--ink); border-radius: 2px;
    padding: .7rem 1.8rem; letter-spacing: .05em;
    transition: all .35s ease;
  }
  .hero-meta a:hover { background: var(--ink); color: var(--paper); }
  .hero-meta .scroll-hint {
    font-family: var(--serif-cn); font-size: .95rem;
    color: var(--ink-faint); letter-spacing: .15em;
    writing-mode: vertical-rl;
  }
  .hero-meta .scroll-hint .arr {
    display: inline-block;
    writing-mode: horizontal-tb;
  }
  .hero-stamp {
    position: absolute; right: 2rem; bottom: 3rem;
    font-family: var(--serif-en); font-style: italic;
    color: var(--ink-faint); font-size: .95rem;
    writing-mode: vertical-rl; letter-spacing: .15em;
    opacity: 0; animation: fade .85s ease forwards .85s;
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-eyebrow, .hero h1 .word, .hero p.lede, .hero-meta, .hero-stamp {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
  @media (max-width: 680px) {
    .hero-stamp { display: none; }
    .hero-meta { flex-direction: column; align-items: flex-start; }
  }
</style>
