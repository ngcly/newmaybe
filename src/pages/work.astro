---
import Base from '../layouts/Base.astro';

// 作品 / 项目数据 —— 往这个数组里加条目即可。
// 如果以后想用 Markdown 管理，可以仿照 posts 再建一个 content collection。
// href 为 null 的条目（如暂无网页的小程序）渲染为纯文本，不生成链接
const works = [
  {
    title: '某个还在构思的东西',
    year: '—',
    type: '待定',
    desc: '也许是一本小册子，也许是一段声音，也许什么都不是。',
    href: null,
    status: '构思中',
  },
  {
    title: '尚未命名的写作计划',
    year: '2026',
    type: '长期 · 写作',
    desc: '一个关于城市夜行与独处的系列随笔，仍在缓慢推进中。',
    href: '/writing',
    status: '进行中',
  },
  {
    title: '桂乡生活',
    year: '2026',
    type: '微信小程序 · 独立开发',
    desc: '服务于咸宁桂花之乡的生活工具。一方水土一方人，用数字的方式连接家乡的日常。',
    href: null,
    status: '设计阶段',
  },
  {
    title: '别让你的脑生锈',
    year: '2026',
    type: '微信小程序 · 独立开发',
    desc: '每日一道数学题，像健身一样锻炼成年人的大脑。没有排行榜、没有社交压力，只是安静地让脑子保持锋利。',
    href: null,
    status: '已上线',
  },
  {
    title: 'newmaybe.com',
    year: '2026',
    type: '网站 · 设计',
    desc: '你正在浏览的这个站点本身。用 Astro 搭建，追求克制与缓慢。',
    href: '/about',
    status: '已上线',
  }
];
---

<Base title="作品" description="一些做过的、正在做的、和也许会做的事。">
  <section class="work">
    <div class="wrap">
      <header class="work-head reveal">
        <span class="eyebrow">Selected Work</span>
        <h1>作品<span class="zh">做过的事</span></h1>
        <p class="intro">
          一些做过的、正在做的、和也许会做的事。
          这里不追求数量，只放一些自己还愿意回头看的。
        </p>
      </header>

      <div class="work-list reveal">
        {works.map((w, i) => {
          const external = w.href != null && /^(https?:\/\/|www\.)/.test(w.href);
          const El = w.href ? 'a' : 'div';
          return (
            <El
              href={w.href ?? undefined}
              class="work-item"
              target={external ? '_blank' : undefined}
              rel={external ? 'noopener noreferrer' : undefined}
            >
              <span class="idx">{String(i + 1).padStart(2, '0')}</span>
              <div class="work-content">
                <div class="work-top">
                  <h2>{w.title}</h2>
                  <span class="status">{w.status}</span>
                </div>
                <p class="work-desc">{w.desc}</p>
                <div class="work-meta">
                  <span>{w.type}</span>
                  <span class="dot-sep">·</span>
                  <span>{w.year}</span>
                </div>
              </div>
            </El>
          );
        })}
      </div>
    </div>
  </section>
</Base>

<style>
  .work { padding: 5rem 0 7rem; }
  .work-head { max-width: 60ch; margin: 0 auto 4.5rem; text-align: center; }
  .eyebrow {
    font-family: var(--serif-en); font-style: italic; font-size: 1.1rem;
    color: var(--ochre); letter-spacing: .05em; display: block; margin-bottom: 1rem;
  }
  .work-head h1 {
    font-weight: 500; font-size: clamp(2.4rem, 6vw, 4rem);
    line-height: 1.15; color: var(--ink); margin-bottom: 1.8rem;
  }
  .work-head h1 .zh {
    font-family: var(--serif-cn); font-size: .55em; color: var(--ink-faint);
    font-weight: 400; margin-left: .6rem;
  }
  .work-head .intro {
    font-size: 1.15rem; line-height: 1.9; color: var(--ink-soft); font-weight: 300;
  }

  .work-list { max-width: var(--max); margin: 0 auto; }
  .work-item {
    display: grid; grid-template-columns: 60px 1fr; gap: 2rem;
    padding: 2.6rem 1.5rem; margin: 0 -1.5rem;
    border-top: 1px solid var(--line);
    text-decoration: none; border-radius: 4px;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                background-color 0.4s ease,
                box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                border-color 0.4s ease;
  }
  .work-item:last-child { border-bottom: 1px solid var(--line); }
  
  a.work-item:hover {
    transform: translateY(-4px);
    background-color: var(--paper-deep);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.02);
    border-color: transparent;
  }
  a.work-item:hover + .work-item {
    border-top-color: transparent;
  }
  :root.dark a.work-item:hover {
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
  }
  .idx {
    font-family: var(--serif-en); font-style: italic; font-size: 1.5rem;
    color: var(--ink-faint); line-height: 1.2;
  }
  .work-top { display: flex; align-items: baseline; justify-content: space-between; gap: 1rem; flex-wrap: wrap; }
  .work-item h2 {
    font-weight: 500; font-size: 1.7rem; color: var(--ink);
    line-height: 1.3; transition: color .3s;
  }
  a.work-item:hover h2 { color: var(--ochre); }
  .status {
    font-family: var(--serif-en); font-style: italic; font-size: .9rem;
    color: var(--ochre); border: 1px solid var(--line); border-radius: 2px;
    padding: .2rem .7rem; white-space: nowrap;
  }
  .work-desc {
    font-size: 1.05rem; line-height: 1.85; color: var(--ink-soft);
    font-weight: 300; margin: .9rem 0; max-width: 58ch;
  }
  .work-meta {
    font-family: var(--serif-en); font-style: italic;
    font-size: .95rem; color: var(--ink-faint); display: flex; gap: .6rem; align-items: center;
  }
  .dot-sep { color: var(--line); }

  @media (max-width: 680px) {
    .work-item {
      grid-template-columns: 1fr; gap: .6rem;
      padding: 2rem 1rem; margin: 0 -1rem;
    }
    .idx { font-size: 1.2rem; }
    .work-item h2 { font-size: 1.4rem; }
  }
</style>
