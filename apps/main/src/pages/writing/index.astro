---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import PostList from '../../components/PostList.astro';
import { sortPostsForDisplay } from '../../lib/posts';

const posts = sortPostsForDisplay(await getCollection('posts', ({ data }) => !data.draft));
const categories = ['全部', ...new Set(posts.map((post) => post.data.category))];
---

<Base title="文字" description="全部文字与随笔。">
  <div style="padding-top: 4rem;">
    <header class="writing-head reveal">
      <span class="eyebrow">Writing</span>
      <h1>文字<span class="zh">全部文章</span></h1>
    </header>
    <div class="category-filter reveal">
      {
        categories.map((cat, idx) => (
          <button class={`filter-btn ${idx === 0 ? 'active' : ''}`} data-category={cat}>
            {cat}
          </button>
        ))
      }
    </div>
    <PostList posts={posts} showMore={false} showHeading={false} />
  </div>
</Base>

<script>
  // WeakMap stores per-button handler references for clean listener removal.
  // Module-scoped so it persists across astro:page-load calls without attaching
  // anything to DOM elements. WeakMap allows GC when elements are removed.
  const _filterClickHandlers = new WeakMap<Element, EventListener>();

  function setupFilters() {
    const buttons = document.querySelectorAll('.filter-btn');
    const posts = document.querySelectorAll('.post');

    buttons.forEach((btn) => {
      // Remove previous listener on the same element before re-binding
      const prev = _filterClickHandlers.get(btn);
      if (prev) btn.removeEventListener('click', prev);

      const clickHandler = () => {
        buttons.forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');

        const selectedCat = btn.getAttribute('data-category');

        posts.forEach((post) => {
          const postCat = post.getAttribute('data-category');
          if (selectedCat === '全部' || postCat === selectedCat) {
            post.classList.remove('hidden');
          } else {
            post.classList.add('hidden');
          }
        });
      };

      btn.addEventListener('click', clickHandler);
      _filterClickHandlers.set(btn, clickHandler);
    });
  }

  // Bind immediately on page load and on transitions
  document.addEventListener('astro:page-load', setupFilters);
</script>

<style>
  .writing-head {
    text-align: center;
    margin: 0 auto 3rem;
    max-width: var(--max);
    padding: 0 2rem;
  }
  .writing-head h1 {
    font-weight: 500;
    font-size: clamp(2.4rem, 6vw, 4rem);
    line-height: 1.15;
    color: var(--ink);
  }
  .category-filter {
    display: flex;
    justify-content: center;
    gap: 1.8rem;
    margin: 0 auto 1.5rem;
    max-width: var(--max);
    padding: 0 2rem;
  }
  .filter-btn {
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--serif-cn);
    font-size: 1.05rem;
    color: var(--ink-faint);
    padding: 0.2rem 0.5rem;
    position: relative;
    transition: color 0.3s ease;
  }
  .filter-btn::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 0;
    height: 1.5px;
    background: var(--ochre);
    transition: width 0.3s ease;
  }
  .filter-btn.active {
    color: var(--ink);
  }
  .filter-btn.active::after {
    width: 100%;
  }
  .filter-btn:hover {
    color: var(--ochre);
  }
</style>
