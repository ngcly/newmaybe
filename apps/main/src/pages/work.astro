---
import Base from '../layouts/Base.astro';
import WorkCardInner from '../components/WorkCardInner.astro';
import { resolveSubdomain } from '../config';

// 作品 / 项目数据 —— 往这个数组里加条目即可。
// 如果以后想用 Markdown 管理，可以仿照 posts 再建一个 content collection。
// href 为 null 的条目（如暂无网页的小程序）渲染为纯文本，不生成链接
const works = [
  {
    title: '思考的经纬',
    year: '2026',
    type: '网站子域 · 关系网络可视化',
    desc: '数字花园的关系网状图谱。全屏渲染 D3 物理力导向图，提取文章、笔记、摘录之间的双向连接线索，支持拖拽缩放与跨域联动阅读。',
    href: 'https://graph.newmaybe.com',
    status: '已上线',
  },
  {
    title: '思考加工厂',
    year: '2026',
    type: '网站子域 · 写作净化与导出',
    desc: '服务于数字花园写作流的排版工具箱。支持中英文混排自动空格优化，以及念头卡片高仿真预览与 YAML Frontmatter 一键复制。',
    href: 'https://tools.newmaybe.com',
    status: '已上线',
  },
  {
    title: '思考 Agent 终端',
    year: '2026',
    type: '网站子域 · 个人知识 Agent',
    desc: '连接数字花园内容仓库的智能园丁。支持通过自然语言问答式检索您的思考与笔记，并自动生成参考引证，支持配置本地 API 推理密钥。',
    href: 'https://ai.newmaybe.com',
    status: '已上线',
  },
  {
    title: '创意实验室',
    year: '2026',
    type: '网站子域 · 交互探索试验场',
    desc: '探索前沿网页交互的温床。包含纯浏览器底层算法合成白噪音的「禅意写作空间」，以及由 Canvas 物理粒子引擎实现的「随风诗句画布」。',
    href: 'https://lab.newmaybe.com',
    status: '已上线',
  },
  {
    title: '思考工坊',
    year: '2026',
    type: '网站子域 · 媒体与素材工坊',
    desc: '专为数字花园打造的生产与创作后台。支持基于 HTML5 Canvas 的排版海报与 OG 分享图实时渲染导出，提供文学写作灵感启发引擎与共享素材资产画廊。',
    href: 'https://studio.newmaybe.com',
    status: '已上线',
  },
  {
    title: '某个还在构思的东西',
    year: '—',
    type: '待定',
    desc: '也许是一本小册子，也许是一段声音，也许什么都不是。',
    href: null,
    status: '构思中',
  },
  {
    title: '尚未命名的写作计划',
    year: '2026',
    type: '长期 · 写作',
    desc: '一个关于城市夜行与独处的系列随笔，仍在缓慢推进中。',
    href: '/writing',
    status: '进行中',
  },
  {
    title: '桂乡生活',
    year: '2026',
    type: '微信小程序 · 独立开发',
    desc: '服务于咸宁桂花之乡的生活工具。一方水土一方人，用数字的方式连接家乡的日常。',
    href: null,
    status: '设计阶段',
  },
  {
    title: '别让你的脑生锈',
    year: '2026',
    type: '微信小程序 · 独立开发',
    desc: '每日一道数学题，像健身一样锻炼成年人的大脑。没有排行榜、没有社交压力，只是安静地让脑子保持锋利。',
    href: null,
    qrcode: '/images/qrcode-rustbrain.png',
    status: '已上线',
  },
  {
    title: 'newmaybe.com',
    year: '2026',
    type: '网站 · 设计',
    desc: '你正在浏览的这个站点本身。用 Astro 搭建，追求克制与缓慢。',
    href: '/about',
    status: '已上线',
  }
];
---

<Base title="作品" description="作品、项目与正在推进的事。">
  <section class="work">
    <div class="wrap">
      <header class="work-head reveal">
        <span class="eyebrow">Selected Work</span>
        <h1>作品<span class="zh">做过的事</span></h1>
        <p class="intro">
          一些做过的、正在做的、和也许会做的事。
          这里不追求数量，只放一些自己还愿意回头看的。
        </p>
      </header>

      <div class="work-list reveal">
        {works.map((w, i) => {
          const external = w.href != null && /^(https?:\/\/|www\.)/.test(w.href);
          const hasQrcode = w.qrcode != null;
          const inner = <WorkCardInner idx={String(i + 1).padStart(2, '0')} title={w.title} status={w.status} desc={w.desc} type={w.type} year={w.year} />;
          return (
            <>
              {w.href ? (
                <a href={external ? resolveSubdomain(w.href) : w.href} class="work-item" target={external ? '_blank' : undefined} rel={external ? 'noopener noreferrer' : undefined}>
                  {inner}
                </a>
              ) : hasQrcode ? (
                <button class="work-item has-qrcode" data-qrcode={w.qrcode} data-title={w.title} data-desc={w.desc} type="button">
                  {inner}
                </button>
              ) : (
                <div class="work-item">
                  {inner}
                </div>
              )}
            </>
          );
        })}
      </div>
    </div>
  </section>

  <!-- 二维码弹窗 Modal -->
  <div class="qr-modal" id="qrModal" aria-hidden="true" role="dialog" aria-labelledby="modalTitle">
    <div class="qr-modal-overlay" id="qrModalOverlay"></div>
    <div class="qr-modal-card">
      <button class="qr-modal-close" id="qrModalClose" aria-label="关闭弹窗">×</button>
      <div class="qr-modal-content">
        <h3 id="modalTitle"></h3>
        <p class="qr-modal-desc" id="modalDesc"></p>
        <div class="qr-code-wrapper">
          <img id="modalQrImg" src="" alt="小程序二维码" />
          <div class="qr-svg-placeholder" id="modalQrPlaceholder">
            <svg viewBox="0 0 100 100" width="100%" height="100%">
              <rect x="0" y="0" width="100" height="100" fill="var(--paper)" />
              <rect x="10" y="10" width="25" height="25" fill="var(--ink)" stroke="var(--paper)" stroke-width="2" />
              <rect x="15" y="15" width="15" height="15" fill="var(--paper)" />
              <rect x="18" y="18" width="9" height="9" fill="var(--ink)" />
              
              <rect x="65" y="10" width="25" height="25" fill="var(--ink)" stroke="var(--paper)" stroke-width="2" />
              <rect x="70" y="15" width="15" height="15" fill="var(--paper)" />
              <rect x="73" y="18" width="9" height="9" fill="var(--ink)" />
              
              <rect x="10" y="65" width="25" height="25" fill="var(--ink)" stroke="var(--paper)" stroke-width="2" />
              <rect x="15" y="70" width="15" height="15" fill="var(--paper)" />
              <rect x="18" y="73" width="9" height="9" fill="var(--ink)" />
              
              <rect x="40" y="10" width="5" height="15" fill="var(--ochre)" />
              <rect x="40" y="30" width="10" height="5" fill="var(--ink)" />
              <rect x="55" y="10" width="5" height="5" fill="var(--ink)" />
              <rect x="50" y="20" width="5" height="15" fill="var(--ink)" />
              <rect x="10" y="45" width="15" height="5" fill="var(--ink)" />
              <rect x="30" y="40" width="5" height="10" fill="var(--ochre)" />
              
              <rect x="40" y="45" width="20" height="20" fill="var(--ink)" />
              <rect x="45" y="50" width="10" height="10" fill="var(--paper)" />
              
              <rect x="65" y="40" width="10" height="5" fill="var(--ink)" />
              <rect x="80" y="40" width="10" height="15" fill="var(--ink)" />
              <rect x="65" y="50" width="5" height="25" fill="var(--ochre)" />
              <rect x="75" y="60" width="15" height="5" fill="var(--ink)" />
              <rect x="75" y="70" width="5" height="15" fill="var(--ink)" />
              <rect x="85" y="75" width="5" height="10" fill="var(--ink)" />
              
              <rect x="40" y="70" width="15" height="5" fill="var(--ink)" />
              <rect x="45" y="80" width="15" height="10" fill="var(--ink)" />
              <rect x="30" y="80" width="5" height="5" fill="var(--ink)" />
            </svg>
          </div>
        </div>
        <p class="qr-modal-hint">微信扫一扫，或在微信内搜索小程序名称</p>
      </div>
    </div>
  </div>

  <script>
    function setupQrModal() {
      const modal = document.getElementById('qrModal');
      const overlay = document.getElementById('qrModalOverlay');
      const closeBtn = document.getElementById('qrModalClose');
      const titleEl = document.getElementById('modalTitle');
      const descEl = document.getElementById('modalDesc');
      const qrImg = document.getElementById('modalQrImg') as HTMLImageElement | null;
      const qrPlaceholder = document.getElementById('modalQrPlaceholder');

      if (!modal) return;

      if (qrImg) {
        qrImg.onerror = () => {
          qrImg.style.display = 'none';
          if (qrPlaceholder) qrPlaceholder.style.display = 'block';
        };
        qrImg.onload = () => {
          qrImg.style.display = 'block';
          if (qrPlaceholder) qrPlaceholder.style.display = 'none';
        };
      }

      const open = (title: string, desc: string, qrcode: string) => {
        if (titleEl) titleEl.textContent = title;
        if (descEl) descEl.textContent = desc;
        if (qrImg) {
          qrImg.style.display = 'none';
          if (qrPlaceholder) qrPlaceholder.style.display = 'block';
          qrImg.src = qrcode;
        }
        
        modal.classList.add('open');
        modal.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
      };

      const close = () => {
        modal.classList.remove('open');
        modal.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
      };

      document.querySelectorAll('.work-item.has-qrcode').forEach(item => {
        item.addEventListener('click', (e) => {
          e.preventDefault();
          const el = e.currentTarget as HTMLElement | null;
          if (!el) return;
          const title = el.getAttribute('data-title') || '';
          const desc = el.getAttribute('data-desc') || '';
          const qrcode = el.getAttribute('data-qrcode') || '';
          open(title, desc, qrcode);
        });
      });

      overlay?.addEventListener('click', close);
      closeBtn?.addEventListener('click', close);

      const handleEsc = (e: KeyboardEvent) => {
        if (e.key === 'Escape') close();
      };
      document.addEventListener('keydown', handleEsc);
      
      (window as any)._cleanupQrModal = () => {
        document.removeEventListener('keydown', handleEsc);
      };
    }

    document.addEventListener('astro:page-load', () => {
      if ((window as any)._cleanupQrModal) {
        (window as any)._cleanupQrModal();
      }
      setupQrModal();
    });
  </script>
</Base>

<style>
  .work { padding: 5rem 0 7rem; }
  .work-head { max-width: 60ch; margin: 0 auto 4.5rem; text-align: center; }
  .eyebrow {
    font-family: var(--serif-en); font-style: italic; font-size: 1.1rem;
    color: var(--ochre); letter-spacing: .05em; display: block; margin-bottom: 1rem;
  }
  .work-head h1 {
    font-weight: 500; font-size: clamp(2.4rem, 6vw, 4rem);
    line-height: 1.15; color: var(--ink); margin-bottom: 1.8rem;
  }
  .work-head h1 .zh {
    font-family: var(--serif-cn); font-size: .55em; color: var(--ink-faint);
    font-weight: 400; margin-left: .6rem;
  }
  .work-head .intro {
    font-size: 1.15rem; line-height: 1.9; color: var(--ink-soft); font-weight: 300;
  }

  .work-list { max-width: var(--max); margin: 0 auto; }
  .work-item {
    display: grid; grid-template-columns: 60px 1fr; gap: 2rem;
    padding: 2.6rem 1.5rem; margin: 0 -1.5rem;
    border-top: 1px solid var(--line);
    text-decoration: none; border-radius: 4px;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                background-color 0.4s ease,
                box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                border-color 0.4s ease;
  }
  .work-item:last-child { border-bottom: 1px solid var(--line); }
  
  div.work-item {
    cursor: default;
    opacity: .75;
  }
  a.work-item:hover,
  button.work-item:hover {
    transform: translateY(-4px);
    background-color: var(--paper-deep);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.02);
    border-color: transparent;
  }
  a.work-item:hover + .work-item,
  button.work-item:hover + .work-item {
    border-top-color: transparent;
  }
  :root.dark a.work-item:hover,
  :root.dark button.work-item:hover {
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
  }
  a.work-item:hover :global(h2),
  button.work-item:hover :global(h2) { color: var(--ochre); }

  @media (max-width: 680px) {
    .work-item {
      grid-template-columns: 1fr; gap: .6rem;
      padding: 2rem 1rem; margin: 0 -1rem;
    }
  }

  /* ── 二维码弹窗 Styles ── */
  .qr-modal {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.4s ease, visibility 0.4s ease;
  }
  .qr-modal.open {
    pointer-events: auto;
    opacity: 1;
    visibility: visible;
  }
  .qr-modal-overlay {
    position: absolute;
    inset: 0;
    background: rgba(30, 25, 18, 0.45);
    backdrop-filter: blur(4px);
  }
  .qr-modal-card {
    position: relative;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 6px;
    width: min(90%, 380px);
    padding: 2.5rem 2rem;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.08);
    transform: scale(0.95) translateY(10px);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    z-index: 10;
  }
  :root.dark .qr-modal-card {
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.35);
  }
  .qr-modal.open .qr-modal-card {
    transform: scale(1) translateY(0);
  }
  .qr-modal-close {
    position: absolute;
    top: 0.5rem;
    right: 1rem;
    background: none;
    border: none;
    font-size: 2rem;
    color: var(--ink-faint);
    cursor: pointer;
    transition: color 0.3s;
    line-height: 1;
  }
  .qr-modal-close:hover {
    color: var(--ochre);
  }
  .qr-modal-content {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .qr-modal-content h3 {
    font-family: var(--serif-cn);
    font-weight: 500;
    font-size: 1.4rem;
    color: var(--ink);
    margin-bottom: 0.6rem;
  }
  .qr-modal-desc {
    font-size: 0.92rem;
    line-height: 1.6;
    color: var(--ink-soft);
    margin-bottom: 1.8rem;
    max-width: 28ch;
  }
  .qr-code-wrapper {
    width: 180px;
    height: 180px;
    border: 1px solid var(--line);
    border-radius: 4px;
    padding: 0.5rem;
    background: var(--paper-deep);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    margin-bottom: 1.5rem;
  }
  .qr-code-wrapper img {
    max-width: 100%;
    max-height: 100%;
    display: none;
  }
  .qr-svg-placeholder {
    width: 100%;
    height: 100%;
  }
  .qr-modal-hint {
    font-size: 0.82rem;
    color: var(--ink-faint);
    letter-spacing: 0.05em;
  }

  /* ── Button work-item overrides ── */
  button.work-item {
    background: none;
    border-left: none;
    border-right: none;
    border-bottom: none;
    width: calc(100% + 3rem);
    text-align: left;
    font-family: inherit;
    font-size: inherit;
    line-height: inherit;
    cursor: pointer;
  }
  a.work-item.has-qrcode:hover :global(h2) {
    color: var(--ochre);
  }
  button.work-item:hover :global(h2) {
    color: var(--ochre);
  }
</style>
