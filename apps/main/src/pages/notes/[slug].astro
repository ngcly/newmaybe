---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { resolveConnections } from '../../lib/connections';

export async function getStaticPaths() {
  const notes = await getCollection('notes', ({ data }) => !data.draft);
  return notes.map((note) => ({
    params: { slug: note.id },
    props: { note },
  }));
}

const { note } = Astro.props;
const { Content } = await render(note);

const longDate = note.data.pubDate.toLocaleDateString('zh-CN', {
  year: 'numeric', month: 'long', day: 'numeric',
});

const updatedDate = note.data.updatedDate?.toLocaleDateString('zh-CN', {
  year: 'numeric', month: 'long', day: 'numeric',
});

const stageInfo = {
  sprout: { icon: '🌱', label: '萌芽 Sprout', class: 'stage-sprout' },
  bud: { icon: '🌿', label: '成长 Bud', class: 'stage-bud' },
  evergreen: { icon: '🌳', label: '常青 Evergreen', class: 'stage-evergreen' }
}[note.data.stage] || { icon: '🌱', label: '萌芽', class: 'stage-sprout' };

// 解析关联节点
const resolvedConnections = await resolveConnections(note.data.connections);

function getUrlForEntry(collection: string, id: string) {
  if (collection === 'posts') return `/writing/${id}`;
  if (collection === 'notes') return `/notes/${id}`;
  if (collection === 'memories') return `/memory/${id}`;
  if (collection === 'fragments') return `/fragments`;
  if (collection === 'excerpts') return `/excerpts`;
  return '#';
}

function getCollectionLabel(collection: string) {
  const labels: Record<string, string> = {
    posts: '文章',
    notes: '笔记',
    memories: '记忆',
    fragments: '念头',
    excerpts: '拾遗'
  };
  return labels[collection] || '内容';
}
---

<Base title={note.data.title} description={`${note.data.title} - 数字花园笔记`}>
  <article class="garden-note">
    <div class="wrap">
      <header class="note-head reveal">
        <a href="/garden" class="back">← 返回花园</a>
        <h1>{note.data.title}</h1>
        
        <div class="note-meta-row">
          <time class="meta-date">发布于 {longDate}</time>
          {updatedDate && <time class="meta-date">· 更新于 {updatedDate}</time>}
        </div>
      </header>

      <div class="note-layout">
        <!-- 笔记正文 -->
        <main class="note-main reveal">
          <div class="prose">
            <Content />
          </div>
        </main>

        <!-- 侧栏/Garden Meta -->
        <aside class="note-sidebar reveal">
          <div class="sidebar-box">
            <h4 class="sidebar-title">花园状态 Garden Meta</h4>
            <div class="meta-item">
              <span class="meta-label">成长阶段</span>
              <span class={`stage-badge ${stageInfo.class}`}>
                {stageInfo.icon} {stageInfo.label}
              </span>
            </div>
            
            {note.data.tags && note.data.tags.length > 0 && (
              <div class="meta-item">
                <span class="meta-label">知识标签</span>
                <div class="meta-tags">
                  {note.data.tags.map(tag => <span class="tag-badge">#{tag}</span>)}
                </div>
              </div>
            )}
          </div>

          <!-- 双向链接/关联网络 -->
          <div class="sidebar-box">
            <h4 class="sidebar-title">知识网络 Connections</h4>
            {resolvedConnections.length > 0 ? (
              <ul class="conn-list">
                {resolvedConnections.map((conn) => (
                  <li>
                    <a href={getUrlForEntry(conn.collection, conn.id)} class="conn-link">
                      <span class="conn-tag">[{getCollectionLabel(conn.collection)}]</span>
                      <span class="conn-title">{conn.data.title || conn.id}</span>
                    </a>
                  </li>
                ))}
              </ul>
            ) : (
              <p class="conn-empty">当前节点暂无外部关联线索。</p>
            )}
          </div>
        </aside>
      </div>
    </div>
  </article>
</Base>

<style>
  .garden-note {
    padding: 5rem 0 7rem;
  }

  .note-head {
    max-width: 100%;
    margin-bottom: 3.5rem;
    border-bottom: 1px solid var(--line);
    padding-bottom: 2rem;
  }
  .back {
    display: inline-block;
    font-family: var(--serif-cn), serif;
    font-size: 0.9rem;
    color: var(--ink-faint);
    text-decoration: none;
    margin-bottom: 1.5rem;
    transition: color 0.3s ease;
  }
  .back:hover {
    color: var(--ochre);
  }
  .note-head h1 {
    font-size: clamp(2rem, 5vw, 2.8rem);
    font-weight: 500;
    color: var(--ink);
    line-height: 1.25;
    margin-bottom: 1.2rem;
  }
  .note-meta-row {
    font-size: 0.9rem;
    color: var(--ink-faint);
    font-family: var(--serif-cn), serif;
  }

  /* 双栏布局 */
  .note-layout {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 4rem;
    align-items: start;
  }

  /* 正文排版 */
  .note-main {
    max-width: 74ch;
  }
  .prose {
    font-family: var(--serif-cn), serif;
    font-size: 1.1rem;
    line-height: 1.95;
    color: var(--ink-soft);
  }
  .prose :global(p) {
    margin-bottom: 1.5rem;
    text-align: justify;
    text-justify: inter-character;
  }
  .prose :global(ul), .prose :global(ol) {
    margin-bottom: 1.5rem;
    padding-left: 1.8rem;
  }
  .prose :global(li) {
    margin-bottom: 0.5rem;
  }
  .prose :global(strong) {
    color: var(--ink);
    font-weight: 500;
  }

  /* 侧栏设计 */
  .note-sidebar {
    position: sticky;
    top: 6rem;
    display: flex;
    flex-direction: column;
    gap: 2.2rem;
  }

  .sidebar-box {
    background: var(--paper-deep);
    border: 1px solid var(--line);
    border-radius: 4px;
    padding: 1.5rem;
  }

  .sidebar-title {
    font-family: var(--serif-cn), serif;
    font-size: 0.85rem;
    color: var(--ochre);
    font-weight: 600;
    letter-spacing: 0.05em;
    margin-bottom: 1.2rem;
    border-bottom: 1px dashed var(--line);
    padding-bottom: 0.6rem;
    text-transform: uppercase;
  }

  .meta-item {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .meta-item + .meta-item {
    margin-top: 1.2rem;
  }
  .meta-label {
    font-size: 0.8rem;
    color: var(--ink-faint);
  }

  /* 状态徽章 */
  .stage-badge {
    display: inline-block;
    padding: 0.3rem 0.6rem;
    font-size: 0.85rem;
    border-radius: 3px;
    font-weight: 500;
    width: fit-content;
  }
  .stage-sprout {
    background: color-mix(in srgb, var(--line) 40%, transparent);
    color: var(--ink-soft);
  }
  .stage-bud {
    background: color-mix(in srgb, var(--ochre) 12%, transparent);
    color: var(--ochre-deep);
  }
  .stage-evergreen {
    background: color-mix(in srgb, var(--ink) 8%, transparent);
    color: var(--ink);
    border: 1px solid var(--line);
  }

  /* 标签 */
  .meta-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .tag-badge {
    font-size: 0.78rem;
    color: var(--ink-soft);
  }

  /* 关系网络列表 */
  .conn-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }
  .conn-link {
    text-decoration: none;
    font-size: 0.88rem;
    line-height: 1.4;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    transition: color 0.3s ease;
  }
  .conn-tag {
    font-size: 0.72rem;
    color: var(--ink-faint);
  }
  .conn-title {
    color: var(--ink-soft);
    font-weight: 400;
    transition: color 0.3s ease;
  }
  .conn-link:hover .conn-title {
    color: var(--ochre);
  }
  .conn-empty {
    font-size: 0.82rem;
    color: var(--ink-faint);
    line-height: 1.6;
    margin: 0;
  }

  @media (max-width: 860px) {
    .note-layout {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .note-sidebar {
      position: static;
      flex-direction: row;
      flex-wrap: wrap;
    }
    .sidebar-box {
      flex: 1 1 280px;
    }
  }
</style>
