---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const notes = (await getCollection('notes', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const fmtDate = (d: Date) =>
  d.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });

// 按成长阶段分组
const stages = {
  evergreen: { label: '常青 🌳', desc: '已经定型、反复引用、沉淀下来的长期价值思想。', notes: [] as typeof notes },
  bud: { label: '成长 🌿', desc: '经历过数次扩写与整理，有了一定结构，仍在不断演化。', notes: [] as typeof notes },
  sprout: { label: '萌芽 🌱', desc: '刚刚闪现的零碎想法，记录在大纲和只言片语中。', notes: [] as typeof notes }
};

notes.forEach(note => {
  if (stages[note.data.stage]) {
    stages[note.data.stage].notes.push(note);
  }
});
---

<Base title="笔记" description="正在成长的数字花园，记录未完成的思考，构建开放的可能性。">
  <section class="notes-page">
    <div class="wrap">
      <header class="page-head reveal">
        <span class="eyebrow">Digital Garden</span>
        <h1>笔记<span class="zh">落叶集</span></h1>
        <p class="intro">这里是我的思维实验室。每一个想法，都从萌芽经历成长，并在此处沉淀。</p>
      </header>

      <div class="notes-container">
        {Object.entries(stages).map(([key, group]) => (
          group.notes.length > 0 && (
            <div class="stage-section reveal">
              <header class="stage-head">
                <h2>{group.label}</h2>
                <p class="stage-desc">{group.desc}</p>
              </header>
              <div class="notes-grid">
                {group.notes.map((note) => (
                  <a href={`/notes/${note.id}`} class="note-card">
                    <span class="card-date">{fmtDate(note.data.pubDate)}</span>
                    <h3 class="card-title">{note.data.title}</h3>
                    {note.data.tags && note.data.tags.length > 0 && (
                      <div class="card-tags">
                        {note.data.tags.map(tag => <span class="tag">#{tag}</span>)}
                      </div>
                    )}
                  </a>
                ))}
              </div>
            </div>
          )
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
  .notes-page {
    padding: 5rem 0 7rem;
  }

  .page-head {
    max-width: 60ch;
    margin: 0 auto 5rem;
    text-align: center;
  }
  .eyebrow {
    font-family: var(--serif-en), serif;
    font-style: italic;
    font-size: 1.1rem;
    color: var(--ochre);
    letter-spacing: .05em;
    display: block;
    margin-bottom: 1rem;
  }
  .page-head h1 {
    font-weight: 500;
    font-size: clamp(2.4rem, 6vw, 4rem);
    line-height: 1.15;
    color: var(--ink);
    margin-bottom: 1.8rem;
  }
  .page-head h1 .zh {
    font-family: var(--serif-cn), serif;
    font-size: .55em;
    color: var(--ink-faint);
    font-weight: 400;
    margin-left: .6rem;
  }
  .page-head .intro {
    font-size: 1.1rem;
    line-height: 1.9;
    color: var(--ink-soft);
    font-weight: 300;
  }

  /* 阶段区块 */
  .notes-container {
    display: flex;
    flex-direction: column;
    gap: 4.5rem;
  }

  .stage-section {
    border-top: 1px solid var(--line);
    padding-top: 2rem;
  }

  .stage-head {
    margin-bottom: 2.2rem;
    max-width: 70ch;
  }
  .stage-head h2 {
    font-family: var(--serif-cn), serif;
    font-size: 1.6rem;
    font-weight: 500;
    color: var(--ink);
    margin-bottom: 0.5rem;
  }
  .stage-desc {
    font-size: 0.92rem;
    color: var(--ink-faint);
    line-height: 1.6;
  }

  /* 笔记网格 */
  .notes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(290px, 1fr));
    gap: 1.8rem;
  }

  /* 笔记卡片 */
  .note-card {
    display: block;
    background: var(--paper-deep);
    border: 1px solid var(--line);
    border-radius: 4px;
    padding: 1.8rem;
    text-decoration: none;
    transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1),
                box-shadow 0.35s cubic-bezier(0.16, 1, 0.3, 1),
                border-color 0.3s ease;
  }

  .note-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.03);
    border-color: color-mix(in srgb, var(--ochre) 25%, var(--line));
  }
  :root.dark .note-card:hover {
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.15);
  }

  .card-date {
    display: block;
    font-family: var(--serif-en), serif;
    font-style: italic;
    font-size: 0.82rem;
    color: var(--ink-faint);
    margin-bottom: 0.6rem;
  }

  .card-title {
    font-family: var(--serif-cn), serif;
    font-size: 1.15rem;
    font-weight: 500;
    color: var(--ink);
    line-height: 1.45;
    margin-bottom: 0.8rem;
    transition: color 0.3s ease;
  }
  .note-card:hover .card-title {
    color: var(--ochre);
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .tag {
    font-size: 0.76rem;
    color: var(--ink-faint);
    opacity: 0.85;
  }

  @media (max-width: 680px) {
    .notes-page {
      padding: 3.5rem 0 5rem;
    }
    .page-head {
      margin-bottom: 3.5rem;
    }
    .notes-grid {
      grid-template-columns: 1fr;
      gap: 1.2rem;
    }
    .note-card {
      padding: 1.4rem;
    }
    .notes-container {
      gap: 3rem;
    }
  }
</style>
