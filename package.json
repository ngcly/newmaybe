{
  "name": "newmaybe-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:main": "npm run dev -w apps/main",
    "dev:graph": "npm run dev -w apps/graph",
    "dev:tools": "npm run dev -w apps/tools",
    "dev:ai": "npm run dev -w apps/ai",
    "dev:lab": "npm run dev -w apps/lab",
    "dev:studio": "npm run dev -w apps/studio",
    "build:main": "npm run build -w apps/main",
    "build:graph": "npm run build -w apps/graph",
    "build:tools": "npm run build -w apps/tools",
    "build:ai": "npm run build -w apps/ai",
    "build:lab": "npm run build -w apps/lab",
    "build:studio": "npm run build -w apps/studio",
    "audit": "npx tsx scripts/audit-posts.ts",
    "new": "npx tsx scripts/new.ts"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9"
  }
}
