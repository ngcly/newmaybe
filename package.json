{
  "name": "newmaybe-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:main": "npm run dev -w apps/main",
    "dev:graph": "npm run dev -w apps/graph",
    "dev:tools": "npm run dev -w apps/tools",
    "dev:ai": "npm run dev -w apps/ai",
    "dev:lab": "npm run dev -w apps/lab",
    "dev:studio": "npm run dev -w apps/studio",
    "build:main": "npm run build -w apps/main",
    "build:graph": "npm run build -w apps/graph",
    "build:tools": "npm run build -w apps/tools",
    "build:ai": "npm run build -w apps/ai",
    "build:lab": "npm run build -w apps/lab",
    "build:studio": "npm run build -w apps/studio",
    "audit": "npx tsx scripts/audit-posts.ts",
    "new": "npx tsx scripts/new.ts",
    "sync:favicon": "for app in graph tools ai lab studio; do cp apps/main/public/favicon.svg apps/main/public/favicon.ico apps/main/public/favicon-32.png apps/main/public/apple-touch-icon.png apps/$app/public/; done && echo 'Favicon synced to all subdomains'",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run lint && npm run format:check",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{astro,css,md,json,yaml,yml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/js-yaml": "^4.0.9",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^3.0.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5",
    "prettier-plugin-astro": "^0.14.1",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  }
}
